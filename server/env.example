PORT=8080
NODE_ENV=production

# 支持配置多个管理员密钥，逗号分隔，便于轮换
ADMIN_API_KEYS=replace_this_with_a_secure_key
PROTECTED_ACCESS_PASSWORD=replace_this_with_the_letters_password

# 本地开发可使用相对路径；生产环境建议改为 /srv/qq-story 下的绝对路径
DATABASE_FILE=database/qq_story.db
UPLOAD_DIR=uploads
LOG_DIR=logs

# 如果配置 CDN 或其他媒体域名，可填入完整前缀
MEDIA_BASE_URL=

ALLOWED_ORIGINS=https://hanbaodoudou.com,https://www.hanbaodoudou.com,https://api.hanbaodoudou.com
MAX_UPLOAD_SIZE_MB=100
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=300
